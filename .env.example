# Frontend environment variables (Vite reads these at build time).
# Copy to .env.local for local dev, or set them in the Vercel dashboard
# under Project Settings → Environment Variables for production.

# Public URL of the deployed FastAPI backend that this frontend should call.
# Local dev default: http://localhost:8000  (used when this var is unset).
# Production example: https://ise547-project.onrender.com
VITE_API_BASE_URL=
