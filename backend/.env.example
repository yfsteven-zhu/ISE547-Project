# Copy this file to .env (or set these in your hosting provider's dashboard)
# and fill in your actual values.

# Required: OpenRouter API key (get one at https://openrouter.ai/keys).
# This must be a SERVER-SIDE secret — never put it in a frontend env var.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: comma-separated list of additional CORS origins to allow,
# beyond the localhost dev defaults. Add your deployed frontend URL here.
# Example:
#   ALLOWED_ORIGINS=https://ise547-project-new.vercel.app,https://my-other-site.com
ALLOWED_ORIGINS=
